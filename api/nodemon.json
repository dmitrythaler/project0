{
  "restartable": "rs",
  "ignore": [
    ".git",
    "node_modules/**/node_modules"
  ],
  "watch": [
    "src/**",
    "../dal/models",
    "../dal/index.ts",
    "../common"
  ],
  "verbose": true,
  "env": {
    "NODE_ENV": "development"
  },
  "ext": "ts,js,json",
  "exec": "node --experimental-loader esbuild-node-loader",
  "legacyWatch": true
}
